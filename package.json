{
  "name": "digital-rain-project",
  "version": "2.0.0",
  "description": "This program displays a digital rain animation within the window browser, as seen in the film The Matrix (1999) or Ghost in the Shell (1995). The user can customize the animation through the menu and through keyboard inputs.",
  "main": "app.js",
  "scripts": {
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . && svelte-check",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "format": "prettier --write .",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MattBunch/Digital-Rain-Project.git"
  },
  "keywords": [],
  "author": "",
  "license": "Apache-2.0",
  "type": "module",
  "bugs": {
    "url": "https://github.com/MattBunch/Digital-Rain-Project/issues"
  },
  "homepage": "https://github.com/MattBunch/Digital-Rain-Project#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-svelte": "^3.17.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.7",
    "svelte-eslint-parser": "^1.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  }
}
